# ╔══════════════════════════════════════════════════════════════╗
# ║           FORENSIC ANALYZER — Configuração de Ambiente       ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Copie este arquivo para .env e preencha com suas credenciais:
#   cp .env.example .env
#
# O arquivo .env NUNCA deve ser commitado no Git.
# Ele já está no .gitignore por padrão.


# ── VirusTotal ───────────────────────────────────────────────────────────────
# Chave de API do VirusTotal (gratuita em https://www.virustotal.com)
# Sem esta chave, a consulta de hash é pulada.
VT_API_KEY=sua_chave_aqui


# ── Configurações opcionais ──────────────────────────────────────────────────

# Timeout em segundos para a requisição ao VirusTotal (padrão: 10)
VT_TIMEOUT=10

# Salvar relatório JSON automaticamente após cada análise (true/false)
# O arquivo será salvo como: relatorio_<nome_do_arquivo>.json
AUTO_SAVE_JSON=false

# Diretório para salvar os relatórios JSON (padrão: diretório atual)
# OUTPUT_DIR=./relatorios
